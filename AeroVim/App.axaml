<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AeroVim.App"
             Name="AeroVim"
             RequestedThemeVariant="Default">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Preferences..."
                            Gesture="⌘+OemComma"
                            Click="OnPreferencesClicked" />
        </NativeMenu>
    </NativeMenu.Menu>
    <Application.Styles>
        <SimpleTheme />
    </Application.Styles>
</Application>
