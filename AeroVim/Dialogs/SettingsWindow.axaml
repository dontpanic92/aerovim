<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AeroVim.ViewModels"
        xmlns:dialogs="using:AeroVim.Dialogs"
        x:Class="AeroVim.Dialogs.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings" Height="520" Width="720"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area: page list + page content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Page list -->
            <ListBox Grid.Column="0" Margin="0,0,10,0"
                     ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding SelectedPage, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SettingsPageViewModel">
                        <TextBlock Text="{Binding DisplayName}" Padding="8,4" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Page content -->
            <ContentControl Grid.Column="1" Content="{Binding SelectedPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:GeneralPageViewModel">
                        <dialogs:GeneralPage />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AppearancePageViewModel">
                        <dialogs:AppearancePage />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ShellIntegrationPageViewModel">
                        <dialogs:ShellIntegrationPage />
                    </DataTemplate>
                    <DataTemplate DataType="vm:AboutPageViewModel">
                        <dialogs:AboutPage />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>

        <!-- Prompt Label -->
        <TextBlock Grid.Row="1" Text="{Binding PromptText}"
                   IsVisible="{Binding IsPromptVisible}"
                   Background="Yellow" Padding="25,5" Margin="0,0,0,5" />

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="76" Margin="0,0,5,0" Click="Ok_Click" />
            <Button Content="Cancel" Width="76" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
