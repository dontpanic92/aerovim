<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Classic.Avalonia.Theme.Controls"
        x:Class="AeroVim.Dialogs.SettingsWindow"
        Title="Settings" Height="520" Width="720"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area: page list + page content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Page list -->
            <ListBox Name="PageListBox" Grid.Column="0" Margin="0,0,10,0"
                     SelectionChanged="PageListBox_SelectionChanged">
                <ListBoxItem Content="General" Padding="8,4" />
                <ListBoxItem Content="Appearance" Padding="8,4" />
                <ListBoxItem Content="About" Padding="8,4" />
            </ListBox>

            <!-- General Page -->
            <StackPanel Name="GeneralPage" Grid.Column="1" Spacing="10">
                <controls:GroupBox Header="Editor Backend" BorderBrush="Gray" BorderThickness="1" Padding="8, 16">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                        <!-- Backend -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Backend"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Name="EditorTypeCombo" Width="120"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="Neovim" />
                            <ComboBoxItem Content="Vim" />
                        </ComboBox>

                        <!-- Neovim Path -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Name="NeovimPathLabel" Text="Neovim Path"
                                   VerticalAlignment="Center" Margin="0,8,10,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" Name="NeovimPathBox" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Name="NeovimPathPanel"
                                    Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Name="BrowseButton" Width="76" Content="Browse..." Click="Browse_Click" />
                            <Button Name="DetectButton" Width="76" Content="Detect" Margin="5,0,0,0" Click="Detect_Click" />
                        </StackPanel>

                        <!-- Vim Path -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Name="VimPathLabel" Text="Vim Path"
                                   VerticalAlignment="Center" Margin="0,8,10,0" />
                        <TextBox Grid.Row="3" Grid.Column="1" Name="VimPathBox" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Name="VimPathPanel"
                                    Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Name="VimBrowseButton" Width="76" Content="Browse..." Click="VimBrowse_Click" />
                            <Button Name="VimDetectButton" Width="76" Content="Detect" Margin="5,0,0,0" Click="VimDetect_Click" />
                        </StackPanel>
                    </Grid>
                </controls:GroupBox>
            </StackPanel>

            <!-- Appearance Page -->
            <StackPanel Name="AppearancePage" Grid.Column="1" IsVisible="False" Spacing="10">
                <!-- Appearance Options -->
                <controls:GroupBox Header="Window" BorderBrush="Gray" BorderThickness="1" Padding="8, 16">
                    <StackPanel>
                        <CheckBox Name="LigatureCheckBox" Content="Enable Font Ligature" Margin="0,0,0,5" />

                        <CheckBox Name="BlurBehindCheckBox" Content="Enable Window Transparency" Margin="0,0,0,5" />

                        <RadioButton Name="TransparentRadio" Content="Transparent"
                                     GroupName="BlurKind" Margin="20,0,0,3" />

                        <RadioButton Name="GaussianRadio" Content="Blur"
                                     GroupName="BlurKind" Margin="20,0,0,3" />

                        <RadioButton Name="AcrylicRadio" Content="Acrylic Blur"
                                     GroupName="BlurKind" Margin="20,0,0,3" />

                        <RadioButton Name="MicaRadio" Content="Mica (Windows only)"
                                     GroupName="BlurKind" Margin="20,0,0,5" />

                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Background Color Opacity" VerticalAlignment="Center" />
                            <Slider Name="OpacitySlider" Width="200" Minimum="0.01" Maximum="1"
                                    TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="10,0" />
                            <TextBlock Name="OpacityLabel" Width="40" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </controls:GroupBox>

                <!-- Fallback Fonts -->
                <controls:GroupBox Header="Fallback Fonts" BorderBrush="Gray" BorderThickness="1" Padding="8, 16">
                    <StackPanel>
                        <TextBlock Text="Searched in order after guifont, before platform defaults."
                                   FontSize="11" Foreground="Gray" Margin="0,0,0,5" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ListBox Name="FontListBox" Grid.Column="0" Height="90" Margin="0,0,5,0" />

                            <StackPanel Grid.Column="1" Spacing="3">
                                <Button Name="FontAddButton" Content="Add..." Width="76" Click="FontAdd_Click" />
                                <Button Name="FontRemoveButton" Content="Remove" Width="76" Click="FontRemove_Click" />
                                <Button Name="FontMoveUpButton" Content="Move Up" Width="76" Click="FontMoveUp_Click" />
                                <Button Name="FontMoveDownButton" Content="Move Down" Width="76" Click="FontMoveDown_Click" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </controls:GroupBox>

            </StackPanel>

            <!-- About Page -->
            <StackPanel Name="AboutPage" Grid.Column="1" IsVisible="False" Spacing="12">
                <Image Source="avares://aerovim/Assets/aerovim.ico" Width="64" Height="64"
                       HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AeroVim" FontSize="24" FontWeight="Bold" />
                    <TextBlock Name="VersionLabel" Text="Version" FontSize="14" Foreground="Gray" />
                </StackPanel>
                <TextBlock Text="Neovim ❤ Acrylic" FontSize="14" Margin="0,4,0,0" />
                <TextBlock Text="Licensed under the GNU General Public License v2.0"
                           Margin="0,8,0,0" TextWrapping="Wrap" />

                <StackPanel Spacing="4" Margin="0,8,0,0">
                    <TextBlock Text="Links" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Name="GitHubLink" Text="GitHub Repository"
                               Foreground="Blue" TextDecorations="Underline"
                               Cursor="Hand" PointerPressed="GitHubLink_PointerPressed" />
                    <TextBlock Name="IssuesLink" Text="Report an Issue"
                               Foreground="Blue" TextDecorations="Underline"
                               Cursor="Hand" PointerPressed="IssuesLink_PointerPressed" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Prompt Label -->
        <TextBlock Grid.Row="1" Name="PromptLabel" IsVisible="False"
                   Background="Yellow" Padding="25,5" Margin="0,0,0,5" />

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="76" Margin="0,0,5,0" Click="Ok_Click" />
            <Button Content="Cancel" Width="76" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
