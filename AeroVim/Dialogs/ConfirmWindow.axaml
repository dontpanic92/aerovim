<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AeroVim.Dialogs.ConfirmWindow"
        Title="Confirm"
        Width="420"
        Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Name="MessageTextBlock"
                   Grid.Row="0"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Yes"
                    Width="76"
                    Margin="0,0,5,0"
                    Click="Yes_Click" />
            <Button Content="No"
                    Width="76"
                    Click="No_Click"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
