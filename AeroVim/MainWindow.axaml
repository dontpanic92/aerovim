<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AeroVim.MainWindow"
        Title="AeroVim"
        RequestedThemeVariant="Light"
        TransparencyLevelHint="None"
        Background="Transparent"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="28"
        SystemDecorations="Full"
        Icon="avares://aerovim/Assets/aerovim.ico">

    <!--
        Custom Window template that replaces Classic.Avalonia's default.
        Classic.Avalonia's template uses FontUtils.FontAliasing which forces
        SubpixelAntialias on the root Panel. Avalonia's RenderOptions.MergeWith
        gives ancestors priority, so no child can override it. This template
        sets Antialias on the root Panel directly, giving the titlebar
        grayscale antialiasing. The editor content is unaffected because
        EditorControl uses ICustomDrawOperation with its own SkiaSharp paints.
    -->
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Panel RenderOptions.TextRenderingMode="Antialias">
                <Border Name="PART_TransparencyFallback"
                        IsHitTestVisible="False" />
                <Border Background="{TemplateBinding Background}"
                        IsHitTestVisible="False" />
                <Panel Margin="{TemplateBinding WindowDecorationMargin}"
                       Background="Transparent" />
                <VisualLayerManager>
                    <VisualLayerManager.ChromeOverlayLayer>
                        <TitleBar />
                    </VisualLayerManager.ChromeOverlayLayer>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </VisualLayerManager>
            </Panel>
        </ControlTemplate>
    </Window.Template>

    <DockPanel LastChildFill="True">
        <!-- Custom Title Bar -->
        <Grid DockPanel.Dock="Top" Height="28" Name="TitleBar" IsHitTestVisible="True"
              PointerPressed="TitleBar_PointerPressed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <TextBlock Grid.Column="1" Name="LogoText"
                       Text="AeroVim" VerticalAlignment="Center"
                       Margin="8,0,8,0"
                       Foreground="White" FontSize="12" FontWeight="Bold" />

            <!-- Title -->
            <TextBlock Grid.Column="2" Name="TitleText" Text="AeroVim"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="8, 0" TextTrimming="CharacterEllipsis"
                       Foreground="White" FontSize="12" />

            <!-- Settings Button -->
            <Button Grid.Column="3" Name="SettingsButton" Content="⚙"
                    Width="46" Height="28" FontSize="14"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="SettingsButton_Click" />

            <!-- Minimize Button -->
            <Button Grid.Column="4" Name="MinimizeButton" Content="🗕"
                    Width="46" Height="28" FontSize="14"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MinimizeButton_Click" />

            <!-- Maximize Button -->
            <Button Grid.Column="5" Name="MaximizeButton" Content="🗖"
                    Width="46" Height="28" FontSize="14"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MaximizeButton_Click" />

            <!-- Close Button -->
            <Button Grid.Column="6" Name="CloseButton" Content="✕"
                    Width="46" Height="28" FontSize="14"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="CloseButton_Click" />
        </Grid>

        <!-- Neovim Control -->
        <Border Name="NeovimBorder" Background="Transparent">
        </Border>
    </DockPanel>
</Window>
