<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AeroVim.MainWindow"
        Title="AeroVim"
        RequestedThemeVariant="Light"
        TransparencyLevelHint="None"
        Background="Transparent"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="Full"
        Icon="avares://aerovim/Assets/aerovim.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="White" />
        <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#40FFFFFF" />
        <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#C42B1C" />
        <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#B22A1C" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.titlebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBarForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.titlebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}" />
        </Style>
        <Style Selector="Button.titlebar-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource TitleBarButtonPressedBrush}" />
        </Style>
        <Style Selector="Button.titlebar-close:pointerover">
            <Setter Property="Background" Value="{DynamicResource TitleBarCloseHoverBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.titlebar-close:pressed">
            <Setter Property="Background" Value="{DynamicResource TitleBarClosePressedBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <!--
        Custom Window template that replaces the default.
        Sets Antialias on the root Panel directly, giving the titlebar
        grayscale antialiasing. The editor content is unaffected because
        EditorControl uses ICustomDrawOperation with its own SkiaSharp paints.
    -->
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Panel TextOptions.TextRenderingMode="Antialias">
                <Border Name="PART_TransparencyFallback"
                        IsHitTestVisible="False" />
                <Border Background="{TemplateBinding Background}"
                        IsHitTestVisible="False" />
                <Panel Margin="{TemplateBinding WindowDecorationMargin}"
                       Background="Transparent" />
                <VisualLayerManager>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </VisualLayerManager>
            </Panel>
        </ControlTemplate>
    </Window.Template>

    <DockPanel LastChildFill="True" DragDrop.AllowDrop="True">
        <!-- Custom Title Bar -->
        <Grid DockPanel.Dock="Top" Height="28" Name="TitleBar" IsHitTestVisible="True"
              PointerPressed="TitleBar_PointerPressed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <TextBlock Grid.Column="1" Name="LogoText"
                       Text="AeroVim" VerticalAlignment="Center"
                       Margin="8,0,8,0"
                       Foreground="{DynamicResource TitleBarForegroundBrush}"
                       FontSize="12" FontWeight="Bold" />

            <!-- Title -->
            <TextBlock Grid.Column="2" Name="TitleText" Text="AeroVim"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="8, 0" TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource TitleBarForegroundBrush}"
                       FontSize="12" />

            <!-- Settings Button with update badge -->
            <Panel Grid.Column="3" Width="46" Height="28">
                <Button Name="SettingsButton" Content="⚙"
                        Classes="titlebar-btn"
                        Width="46" Height="28" FontSize="14"
                        CornerRadius="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Focusable="False"
                        Click="SettingsButton_Click" />
                <Ellipse Name="UpdateBadge"
                         Width="8" Height="8"
                         Fill="#FF3B30"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,4,6,0"
                         IsHitTestVisible="False"
                         IsVisible="False" />
            </Panel>

            <!-- Minimize Button -->
            <Button Grid.Column="4" Name="MinimizeButton" Content="🗕"
                    Classes="titlebar-btn"
                    Width="46" Height="28" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MinimizeButton_Click" />

            <!-- Maximize Button -->
            <Button Grid.Column="5" Name="MaximizeButton" Content="🗖"
                    Classes="titlebar-btn"
                    Width="46" Height="28" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MaximizeButton_Click" />

            <!-- Close Button -->
            <Button Grid.Column="6" Name="CloseButton" Content="✕"
                    Classes="titlebar-btn titlebar-close"
                    Width="46" Height="28" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="CloseButton_Click" />
        </Grid>

        <!-- Neovim Control -->
        <Border Name="NeovimBorder" Background="Transparent">
        </Border>
    </DockPanel>
</Window>
